APP_NAME="College CMS"
APP_ENV=production
APP_KEY=                          # Generated by setup.php
APP_DEBUG=true
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=             # Use a dedicated least-privilege user, NOT root
DB_PASSWORD=                      # Strong random password

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true        # Must be true in production (HTTPS required)
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_ABSOLUTE_TIMEOUT=480
SESSION_EXPIRE_ON_CLOSE=false

QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log

MEDIA_DRIVER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
